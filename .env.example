# ──────────────────────────────────────────────────────────────
# Perry's Wan 2.2 Pipeline — environment template
# ──────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored and must NEVER be committed.
#
#     cp .env.example .env
#
# These credentials drive the MasterKey prompt-enhancement stage.
# Paste the matching value into the node's api_key widget at runtime,
# or load it however your node package expects.
# ──────────────────────────────────────────────────────────────

# Credential for: tech, universal, close, people workflows
GEMINI_API_KEY=your_key_here

# Credential for: jewellery workflow
GEMINI_API_KEY_JEWELLERY=your_key_here

# ── Optional runtime paths / settings ─────────────────────────
# COMFYUI_PORT=8188
# MODELS_BASE_PATH=/absolute/path/to/perry-wan-pipeline/models
# OUTPUT_PATH=/absolute/path/to/perry-wan-pipeline/outputs
# INPUT_PATH=/absolute/path/to/perry-wan-pipeline/inputs
